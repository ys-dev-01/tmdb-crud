# Copy this file to .env and fill in actual values.
# .env is gitignored; .env.example documents the contract.
#
# Each PR in the build sequence appends the env vars it needs here,
# so .env.example always reflects the full surface the app reads.

# --- Application ---
NODE_ENV=development
PORT=8080

# --- Database (PostgreSQL) ---
# When the app runs inside docker-compose, DB_HOST=postgres (the compose service name).
# When the app runs on the host against a dockerized DB, DB_HOST=localhost.
DB_HOST=postgres
DB_PORT=5432
DB_USER=tmdb
DB_PASSWORD=tmdb_dev_password
DB_NAME=tmdb

# --- TMDB ---
# Get a key from https://www.themoviedb.org/settings/api (v3 auth, 32 hex chars).
TMDB_API_KEY=your_tmdb_v3_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
